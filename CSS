body{
font-family: Arial;
margin:0;
background:#f4f4f4;
}

nav{
display:flex;
justify-content:center;
gap:60px;
padding:20px;
}

.hero{
background:#d9d9d9;
width:600px;
margin:40px auto;
text-align:center;
padding:40px;
border-radius:6px;
}

.new-books{
text-align:center;
}

.book-container{
display:flex;
justify-content:center;
gap:120px;
margin-top:40px;
}

.book-card{
background:#9e9e9e;
width:120px;
height:120px;
display:flex;
flex-direction:column;
align-items:center;
justify-content:center;
}

.categories{
text-align:center;
margin-top:50px;
}

.cat-container{
display:flex;
justify-content:center;
gap:60px;
margin-top:20px;
}

.cat{
background:#9e9e9e;
padding:15px 25px;
}

footer{
display:flex;
justify-content:space-between;
padding:60px;
}
